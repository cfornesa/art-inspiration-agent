run = "uv run python main.py"

modules = ["python-3.11"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["libxcrypt"]

[workflows]

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "5000"]

[objectStorage]
defaultBucketID = "replit-objstore-b3c3987e-1594-4ff1-827f-f9cd6ee2fbb7"
